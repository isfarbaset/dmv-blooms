];

/* ============================================================
   UTILITIES
   ============================================================ */
function status(b) {
  if (b.n === "Cherry Blossoms") {
    if (CM === 2 && CD >= 20) return "peak";
    if (CM === 3 && CD <= 10) return "peak";
    if (CM === 3) return "ending";
    if (CM === 2) return "blooming";
  }
  if (b.pk.includes(CM)) return "peak";
  if (b.mo.includes(CM)) return "blooming";
  if (b.mo.includes((CM + 1) % 12) || b.mo.includes((CM + 2) % 12)) return "upcoming";
  return "waiting";
}
function stLabel(s) {
  return { peak:"Peak Bloom", blooming:"Blooming", ending:"Fading", upcoming:"Coming Soon", waiting:"Dormant" }[s] || s;
}
function stClass(s) {
  return { peak:"st-peak", blooming:"st-blooming", ending:"st-ending", upcoming:"st-upcoming", waiting:"st-waiting" }[s] || "";
}
function locStatus(loc) {
  let best = "waiting";
  const ord = ["peak","blooming","ending","upcoming","waiting"];
  loc.fl.forEach(f => {
    const b = BLOOMS.find(x => x.n === f);
    if (b) { const s = status(b); if (ord.indexOf(s) < ord.indexOf(best)) best = s; }
  });
  return best;
}
function shareBloom(bloom) {
  const text = `${bloom.n} — ${stLabel(status(bloom)).toLowerCase()} in the DMV right now.\n\nBest spots: ${bloom.loc.slice(0,3).join(', ')}\nPeak: ${bloom.wk}\n\nExplore more: isfarbaset.github.io/dmv-blooms`;
  if (navigator.share) {
    navigator.share({ title: `${bloom.n} — DMV Blooms`, text }).catch(() => {});
  } else {
    navigator.clipboard.writeText(text).then(() => {
      const t = document.getElementById('share-toast');
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2200);
    });
  }
}
const SHARE_SVG = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>';
const PIN_SVG = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>';

/* ============================================================
   PRELOADER
   ============================================================ */
window.addEventListener('load', () => {
  setTimeout(() => {
    document.getElementById('preloader').classList.add('done');
    initAnimations();
  }, 800);
});

/* ============================================================
   CUSTOM CURSOR
   ============================================================ */
(function() {
  const cursor = document.getElementById('cursor');
  if (!cursor || !window.matchMedia('(hover:hover) and (pointer:fine)').matches) return;
  let mx = 0, my = 0, cx = 0, cy = 0;
  document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; cursor.classList.add('visible'); });
  document.addEventListener('mouseleave', () => cursor.classList.remove('visible'));
  (function loop() {
    cx += (mx - cx) * 0.15; cy += (my - cy) * 0.15;
    cursor.style.left = cx + 'px'; cursor.style.top = cy + 'px';
    requestAnimationFrame(loop);
  })();
  document.addEventListener('mouseenter', e => {
    if (e.target.closest('a,button,.loc-tag,.gallery-card,.dest-card,.weekend-card,.map-filter,.bar')) {
      cursor.classList.add('hover');
    }
  }, true);
  document.addEventListener('mouseleave', e => {
    if (e.target.closest('a,button,.loc-tag,.gallery-card,.dest-card,.weekend-card,.map-filter,.bar')) {
      cursor.classList.remove('hover');
    }
  }, true);
})();

/* ============================================================
   NAVIGATION
   ============================================================ */
(function() {
  const nav = document.getElementById('nav');
  const toggle = document.getElementById('nav-toggle');
  const links = document.getElementById('nav-links');

  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 80);
  });

  toggle.addEventListener('click', () => {
    links.classList.toggle('open');
  });

  links.querySelectorAll('.nav-link').forEach(a => {
    a.addEventListener('click', () => links.classList.remove('open'));
  });
})();

/* ============================================================
   FLOATING PETALS
   ============================================================ */
(function() {
  const container = document.getElementById('petals');
  for (let i = 0; i < 15; i++) {
    const p = document.createElement('div');
    p.className = 'petal';
    p.style.left = Math.random() * 100 + '%';
    p.style.width = (6 + Math.random() * 10) + 'px';
    p.style.height = p.style.width;
    p.style.animationDuration = (8 + Math.random() * 12) + 's';
    p.style.animationDelay = (Math.random() * 10) + 's';
    p.style.opacity = 0.15 + Math.random() * 0.2;
    container.appendChild(p);
  }
})();

/* ============================================================
   MARQUEE
   ============================================================ */
(function() {
  const track = document.getElementById('marquee-track');
  const names = BLOOMS.map(b => b.n);
  let html = '';
  // Duplicate for seamless loop
  for (let r = 0; r < 2; r++) {
    names.forEach(n => {
      html += `<span class="marquee-item">${n}<span class="marquee-dot"></span></span>`;
    });
  }
  track.innerHTML = html;
})();

/* ============================================================
   RENDER: HERO COUNT
   ============================================================ */
function renderHeroCount() {
  const active = BLOOMS.filter(b => ['peak','blooming','ending'].includes(status(b)));
  document.getElementById('hero-count').textContent = `${active.length} flower${active.length !== 1 ? 's' : ''} in bloom`;
  document.getElementById('stat-active').textContent = active.length;
}

/* ============================================================
   RENDER: GALLERY (Horizontal scroll)
   ============================================================ */
function renderGallery() {
  const track = document.getElementById('gallery-track');
  const mn = NOW.toLocaleString('default', { month: 'long' });
  document.getElementById('gallery-desc').textContent = `Everything flowering across the DMV this ${mn}, sorted by what's peaking first.`;

  const ord = { peak:0, blooming:1, ending:2, upcoming:3, waiting:4 };
  const sorted = [...BLOOMS].map(b => ({ ...b, st: status(b) })).sort((a, b) => ord[a.st] - ord[b.st]);

  track.innerHTML = sorted.map(b => `
    <div class="gallery-card" onclick="document.getElementById('guide').scrollIntoView({behavior:'smooth'})">
      <img class="gallery-card-img" src="${b.img}" alt="${b.n}" loading="lazy" onerror="this.style.background='${b.c}'">
      <div class="gallery-card-status ${stClass(b.st)}">${stLabel(b.st)}</div>
      <div class="gallery-card-info">
        <div class="gallery-card-name">${b.n}</div>
        <div class="gallery-card-when">${b.wk}</div>
      </div>
    </div>
  `).join('');
}

/* ============================================================
   RENDER: WEEKEND EDIT
   ============================================================ */
function renderWeekend() {
  const dow = NOW.getDay();
  const sat = new Date(NOW); sat.setDate(NOW.getDate() + ((6 - dow + 7) % 7 || (dow === 6 ? 0 : 7)));
  const sun = new Date(sat); sun.setDate(sat.getDate() + 1);
  const isWknd = dow === 0 || dow === 6;
  const label = isWknd ? "This weekend" :
    `${sat.toLocaleDateString('en-US',{month:'long',day:'numeric'})} – ${sun.toLocaleDateString('en-US',{month:'long',day:'numeric'})}`;

  document.getElementById('weekend-title').textContent = `Where to go ${isWknd ? 'this weekend' : 'next'}`;

  const active = BLOOMS.map(b => ({ ...b, st: status(b) })).filter(b => ['peak','blooming','ending'].includes(b.st));
  const picks = []; const used = new Set();
  active.sort((a, b) => { const o = {peak:0,blooming:1,ending:2}; return o[a.st] - o[b.st]; })
    .forEach(bl => {
      const l = LOCS.filter(x => x.fl.includes(bl.n) && !used.has(x.n));
      if (l.length) { used.add(l[0].n); picks.push({ bl, loc: l[0] }); }
    });

  const grid = document.getElementById('weekend-grid');
  if (picks.length === 0) {
    grid.innerHTML = '<p style="font-family:var(--serif);font-style:italic;color:var(--text-light);">No flowers are actively blooming this weekend. Check the calendar for upcoming blooms.</p>';
    return;
  }

  const tagClass = s => ({ peak:'pk', blooming:'bl', ending:'en' }[s] || '');
  const featured = picks[0];
  const rest = picks.slice(1, 4);

  grid.innerHTML = `
    <div class="weekend-card reveal">
      <img class="weekend-card-img" src="${featured.loc.img}" alt="${featured.loc.n}" loading="lazy" onerror="this.style.background='${featured.bl.c}'">
      <div class="weekend-card-overlay"></div>
      <div class="weekend-card-content">
        <div class="weekend-card-tag ${tagClass(featured.bl.st)}">${stLabel(featured.bl.st)}</div>
        <div class="weekend-card-title">${featured.bl.n} at ${featured.loc.n}</div>
        <div class="weekend-card-loc">${PIN_SVG} ${featured.loc.n}, ${featured.loc.r}</div>
        <div class="weekend-card-desc">${featured.loc.d}</div>
      </div>
    </div>
    <div class="weekend-side">
      ${rest.map(p => `
        <div class="weekend-card reveal">
          <img class="weekend-card-img" src="${p.loc.img}" alt="${p.loc.n}" loading="lazy" onerror="this.style.background='${p.bl.c}'">
          <div class="weekend-card-overlay"></div>
          <div class="weekend-card-content">
            <div class="weekend-card-tag ${tagClass(p.bl.st)}">${stLabel(p.bl.st)}</div>
            <div class="weekend-card-title">${p.bl.n}</div>
            <div class="weekend-card-loc">${PIN_SVG} ${p.loc.n}</div>
          </div>
        </div>
      `).join('')}
    </div>
  `;
}

/* ============================================================
   RENDER: BLOOM GUIDE (Editorial blocks)
   ============================================================ */
function renderGuide() {
  const container = document.getElementById('guide-container');
  const ord = { peak:0, blooming:1, ending:2, upcoming:3, waiting:4 };
  const sorted = [...BLOOMS].map(b => ({ ...b, st: status(b) })).sort((a, b) => ord[a.st] - ord[b.st]);

  container.innerHTML = sorted.map((b, i) => `
    <div class="guide-block">
      <div class="guide-text ${i % 2 === 0 ? 'reveal-slide-left' : 'reveal-slide-right'}">
        <div class="guide-flower-when">${stLabel(b.st)} · ${b.wk}</div>
        <h3 class="guide-flower-name">${b.n}</h3>
        <p class="guide-flower-desc">${b.d}</p>
        <div class="guide-locations">
          ${b.loc.map(l => {
            const loc = LOCS.find(x => x.n === l || l.startsWith(x.n));
            return `<span class="loc-tag" data-lat="${loc ? loc.la : ''}" data-lng="${loc ? loc.ln : ''}" data-name="${l}">${l}</span>`;
          }).join('')}
        </div>
        <button class="guide-share" onclick='shareBloom(BLOOMS[${BLOOMS.indexOf(BLOOMS.find(x => x.n === b.n))}])'>${SHARE_SVG} Share</button>
      </div>
      <div class="guide-img ${i % 2 === 0 ? 'reveal-slide-right' : 'reveal-slide-left'}">
        <img src="${b.img}" alt="${b.n}" loading="lazy" onerror="this.parentElement.style.background='${b.c}'">
      </div>
    </div>
  `).join('');
}

/* ============================================================
   RENDER: DESTINATIONS
   ============================================================ */
function renderDestinations() {
  const grid = document.getElementById('dest-grid');
  grid.innerHTML = LOCS.map(loc => {
    const s = locStatus(loc);
    return `
      <div class="dest-card reveal" data-lat="${loc.la}" data-lng="${loc.ln}" data-name="${loc.n}">
        <img class="dest-card-img" src="${loc.img}" alt="${loc.n}" loading="lazy" onerror="this.style.background='${loc.c}'">
        <div class="dest-card-overlay"></div>
        <div class="dest-card-region">${loc.r}</div>
        <div class="dest-card-content">
          <div class="dest-card-name">${loc.n}</div>
          <div class="dest-card-flowers">${loc.fl.join(' · ')}</div>
        </div>
      </div>
    `;
  }).join('');
}

/* ============================================================
   RENDER: CALENDAR
   ============================================================ */
function renderCalendar() {
  const t = document.getElementById('cal-table');
  let html = '<thead><tr><th></th>';
  MONTHS.forEach((m, i) => { html += `<th class="${i === CM ? 'current' : ''}">${m}</th>`; });
  html += '</tr></thead><tbody>';
  BLOOMS.forEach(b => {
    html += `<tr><td>${b.n}</td>`;
    for (let m = 0; m < 12; m++) {
      if (b.pk.includes(m)) html += `<td><div class="bar peak"></div></td>`;
      else if (b.mo.includes(m)) html += `<td><div class="bar bloom"></div></td>`;
      else html += '<td></td>';
    }
    html += '</tr>';
  });
  t.innerHTML = html + '</tbody>';
}

/* ============================================================
   RENDER: MAP
   ============================================================ */
let map; let markers = [];
function renderMap() {
  map = L.map('leaflet-map', { zoomControl: true, scrollWheelZoom: true }).setView([38.92, -77.04], 11);
  L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
    maxZoom: 18,
    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/">CARTO</a>'
  }).addTo(map);

  const stColors = { peak:'#e4ebe0', blooming:'#f5eed8', ending:'#f3eaea', upcoming:'#dde5ee', waiting:'#eee' };
  const stTxt = { peak:'#5e6b52', blooming:'#8b7420', ending:'#9E5A62', upcoming:'#4A6B8A', waiting:'#888' };

  LOCS.forEach(loc => {
    const s = locStatus(loc);
    const icon = L.divIcon({
      html: `<div class="custom-marker" style="background:${loc.c}"><img src="${loc.img}" alt="${loc.n}" onerror="this.style.display='none'"></div>`,
      className: '', iconSize: [36, 36], iconAnchor: [18, 18], popupAnchor: [0, -22]
    });
    const mk = L.marker([loc.la, loc.ln], { icon }).addTo(map);
    mk.region = loc.r; mk.locData = loc;
    const fl = loc.fl.join(' · ');
    mk.bindPopup(`
      <div class="map-popup">
        <img class="map-popup-img" src="${loc.img}" alt="${loc.n}" loading="lazy" onerror="this.style.display='none'">
        <div class="map-popup-body">
          <div class="map-popup-name">${loc.n}</div>
          <div class="map-popup-flowers">${fl}</div>
          <div class="map-popup-desc">${loc.d}</div>
          <span class="map-popup-status" style="background:${stColors[s]};color:${stTxt[s]}">${stLabel(s)}</span>
        </div>
      </div>
    `, { maxWidth: 280 });
    markers.push(mk);
  });

  // Filters
  const bar = document.getElementById('map-filters');
  bar.innerHTML = `
    <button class="map-filter active" data-f="all">All</button>
    <button class="map-filter" data-f="DC">DC</button>
    <button class="map-filter" data-f="MD">Maryland</button>
    <button class="map-filter" data-f="VA">Virginia</button>
    <button class="map-filter" data-f="bloom">In Bloom</button>
  `;
  bar.addEventListener('click', e => {
    if (!e.target.classList.contains('map-filter')) return;
    bar.querySelectorAll('.map-filter').forEach(b => b.classList.remove('active'));
    e.target.classList.add('active');
    const f = e.target.dataset.f;
    const vis = [];
    markers.forEach(m => {
      const s = locStatus(m.locData);
      const show = f === 'all' || (f === 'bloom' ? ['peak','blooming','ending'].includes(s) : m.region === f);
      if (show) { if (!map.hasLayer(m)) map.addLayer(m); vis.push(m); }
      else { if (map.hasLayer(m)) map.removeLayer(m); }
    });
    if (vis.length) map.fitBounds(L.featureGroup(vis).getBounds().pad(0.12));
  });
}

/* ============================================================
   LOCATION MAP PREVIEW (hover tooltip)
   ============================================================ */
let tooltipMap = null;
const tooltip = document.getElementById('map-tooltip');
const tooltipMapEl = document.getElementById('map-tooltip-map');
const tooltipName = document.getElementById('map-tooltip-name');

function showMapTooltip(e, lat, lng, name) {
  if (!lat || !lng) return;
  const rect = e.target.getBoundingClientRect();
  let left = rect.left + rect.width / 2 - 140;
  let top = rect.top - 210;
  if (top < 10) top = rect.bottom + 10;
  if (left < 10) left = 10;
  if (left + 280 > window.innerWidth - 10) left = window.innerWidth - 290;
  tooltip.style.left = left + 'px';
  tooltip.style.top = top + 'px';
  tooltipName.textContent = name;

  if (tooltipMap) { tooltipMap.remove(); tooltipMap = null; }
  tooltip.classList.add('visible');

  setTimeout(() => {
    tooltipMap = L.map(tooltipMapEl, {
      zoomControl: false, attributionControl: false,
      dragging: false, scrollWheelZoom: false,
      doubleClickZoom: false, touchZoom: false
    }).setView([parseFloat(lat), parseFloat(lng)], 14);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', { maxZoom: 18 }).addTo(tooltipMap);
    L.circleMarker([parseFloat(lat), parseFloat(lng)], {
      radius: 6, fillColor: '#5e6b52', fillOpacity: 1, color: '#fff', weight: 2
    }).addTo(tooltipMap);
  }, 50);
}

function hideMapTooltip() {
  tooltip.classList.remove('visible');
  if (tooltipMap) { tooltipMap.remove(); tooltipMap = null; }
}

document.addEventListener('mouseenter', e => {
  const tag = e.target.closest('.loc-tag, .dest-card');
  if (!tag) return;
  const lat = tag.dataset.lat, lng = tag.dataset.lng, name = tag.dataset.name;
  if (lat && lng) showMapTooltip(e, lat, lng, name);
}, true);

document.addEventListener('mouseleave', e => {
  const tag = e.target.closest('.loc-tag, .dest-card');
  if (tag) hideMapTooltip();
}, true);

/* ============================================================
   GSAP SCROLL ANIMATIONS
   ============================================================ */
function initAnimations() {
  gsap.registerPlugin(ScrollTrigger);

  // Reveal on scroll (general)
  document.querySelectorAll('.reveal, .reveal-slide-left, .reveal-slide-right').forEach(el => {
    ScrollTrigger.create({
      trigger: el,
      start: 'top 85%',
      onEnter: () => el.classList.add('visible'),
    });
  });

  // Image reveals
  document.querySelectorAll('.reveal-img').forEach(el => {
    ScrollTrigger.create({
      trigger: el,
      start: 'top 80%',
      onEnter: () => el.classList.add('visible'),
    });
  });

  // Hero parallax
  gsap.to('.hero-content', {
    y: 120, opacity: 0.3,
    scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 1 }
  });
  gsap.to('.hero-bg', {
    y: 80,
    scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 1 }
  });

  // Gallery horizontal scroll
  const galleryTrack = document.getElementById('gallery-track');
  if (galleryTrack && galleryTrack.scrollWidth > window.innerWidth) {
    gsap.to(galleryTrack, {
      x: () => -(galleryTrack.scrollWidth - window.innerWidth + 60),
      ease: 'none',
      scrollTrigger: {
        trigger: '#in-season',
        start: 'top 10%',
        end: () => `+=${galleryTrack.scrollWidth - window.innerWidth + 200}`,
        scrub: 1,
        pin: true,
        anticipatePin: 1,
      }
    });
  }

  // Parallax divider
  gsap.to('.parallax-bg', {
    y: -60,
    scrollTrigger: { trigger: '.parallax-divider', start: 'top bottom', end: 'bottom top', scrub: 1 }
  });

  // Guide blocks: parallax images
  document.querySelectorAll('.guide-block').forEach(block => {
    const img = block.querySelector('.guide-img img');
    if (img) {
      gsap.fromTo(img, { y: -30 }, {
        y: 30, ease: 'none',
        scrollTrigger: { trigger: block, start: 'top bottom', end: 'bottom top', scrub: 1 }
      });
    }
  });

  // Destination cards stagger
  const destCards = document.querySelectorAll('.dest-card');
  if (destCards.length) {
    ScrollTrigger.batch(destCards, {
      start: 'top 85%',
      onEnter: batch => {
        batch.forEach((el, i) => {
          setTimeout(() => el.classList.add('visible'), i * 80);
        });
      }
    });
  }

  // Calendar bars animate in
  ScrollTrigger.create({
    trigger: '.cal-wrap',
    start: 'top 80%',
    onEnter: () => {
      document.querySelectorAll('.bar').forEach((bar, i) => {
        bar.style.opacity = '0';
        bar.style.transform = 'scaleX(0)';
        bar.style.transformOrigin = 'left';
        bar.style.transition = `opacity 0.4s ${i * 0.02}s, transform 0.5s ${i * 0.02}s var(--ease-out)`;
        requestAnimationFrame(() => {
          bar.style.opacity = '1';
          bar.style.transform = 'scaleX(1)';
        });
      });
    }
  });

  // Stat counter animation
  document.querySelectorAll('.stat-num').forEach(el => {
    const target = parseInt(el.textContent);
    if (isNaN(target)) return;
    ScrollTrigger.create({
      trigger: el,
      start: 'top 85%',
      onEnter: () => {
        let current = 0;
        const step = Math.ceil(target / 30);
        const interval = setInterval(() => {
          current += step;
          if (current >= target) { current = target; clearInterval(interval); }
          el.textContent = current;
        }, 30);
      }
    });
  });
}

/* ============================================================
   YEAR IN FOOTER
   ============================================================ */
document.getElementById('year').textContent = new Date().getFullYear();

/* ============================================================
   INIT
   ============================================================ */
document.addEventListener('DOMContentLoaded', () => {
  renderHeroCount();
  renderGallery();
  renderWeekend();
  renderGuide();
  renderDestinations();
  renderCalendar();
  renderMap();
});
</script>
</body>
</html>
