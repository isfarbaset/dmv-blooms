<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DMV Blooms — A Seasonal Flower Guide for DC, Maryland & Virginia</title>
<meta name="description" content="An editorial guide to the most beautiful blooms across Washington DC, Maryland and Virginia. Discover what's flowering, where to go, and when to visit.">
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><circle cx='50' cy='50' r='40' fill='%235e6b52'/><circle cx='50' cy='38' r='12' fill='%23f5f0ea'/><circle cx='38' cy='50' r='12' fill='%23f5f0ea'/><circle cx='62' cy='50' r='12' fill='%23f5f0ea'/><circle cx='50' cy='62' r='12' fill='%23f5f0ea'/><circle cx='50' cy='50' r='6' fill='%23b8956a'/></svg>">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Inter:ital,wght@0,300;0,400;0,500;1,300;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<style>
/* ============================================================
   DESIGN TOKENS
   ============================================================ */
:root {
  --bg: #f5f0ea;
  --bg-dark: #1a1815;
  --bg-mid: #eae4db;
  --text: #1a1815;
  --text-light: #6b6560;
  --text-muted: #a09a93;
  --accent: #8b6d5c;
  --sage: #5e6b52;
  --sage-light: #e4ebe0;
  --rose: #b08888;
  --rose-light: #f3eaea;
  --gold: #b8956a;
  --white: #fdfcf9;
  --border: #ddd7ce;
  --shadow-sm: 0 2px 8px rgba(26,24,21,0.06);
  --shadow-md: 0 8px 30px rgba(26,24,21,0.08);
  --shadow-lg: 0 20px 60px rgba(26,24,21,0.12);
  --serif: 'Cormorant Garamond', 'Georgia', serif;
  --sans: 'Inter', system-ui, -apple-system, sans-serif;
  --ease: cubic-bezier(0.25, 0.46, 0.45, 0.94);
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
}

/* ============================================================
   RESET & BASE
   ============================================================ */
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;font-size:16px;}
body{
  font-family:var(--sans);background:var(--bg);color:var(--text);
  line-height:1.6;overflow-x:hidden;-webkit-font-smoothing:antialiased;
  -moz-osx-font-smoothing:grayscale;
}
img{max-width:100%;display:block;}
a{color:inherit;text-decoration:none;}
button{font-family:inherit;cursor:pointer;border:none;background:none;}
::selection{background:var(--sage);color:var(--white);}

/* subtle grain texture */
body::after{
  content:'';position:fixed;inset:0;z-index:99999;pointer-events:none;opacity:0.018;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
}

/* ============================================================
   PRELOADER
   ============================================================ */
.preloader{
  position:fixed;inset:0;z-index:100000;background:var(--bg-dark);
  display:flex;align-items:center;justify-content:center;
  transition:opacity 0.8s var(--ease), visibility 0.8s;
}
.preloader.done{opacity:0;visibility:hidden;pointer-events:none;}
.preloader-text{
  font-family:var(--serif);font-size:clamp(1.5rem,4vw,2.5rem);
  font-weight:300;color:var(--bg);letter-spacing:0.15em;text-transform:uppercase;
  opacity:0;animation:preloaderIn 0.8s var(--ease-out) 0.2s forwards;
}
@keyframes preloaderIn{to{opacity:1;}}

/* ============================================================
   CUSTOM CURSOR (desktop only)
   ============================================================ */
@media(hover:hover)and(pointer:fine){
  .cursor{
    position:fixed;top:0;left:0;z-index:99998;pointer-events:none;
    width:10px;height:10px;border-radius:50%;
    background:var(--text);mix-blend-mode:difference;
    transition:width 0.3s var(--ease-out),height 0.3s var(--ease-out),opacity 0.3s;
    transform:translate(-50%,-50%);opacity:0;
  }
  .cursor.visible{opacity:1;}
  .cursor.hover{width:40px;height:40px;}
  body{cursor:none;}
  body *{cursor:none;}
}

/* ============================================================
   NAVIGATION
   ============================================================ */
.nav{
  position:fixed;top:0;left:0;right:0;z-index:5000;
  padding:0 clamp(1.5rem,4vw,3rem);height:72px;
  display:flex;align-items:center;justify-content:space-between;
  transition:background 0.4s,backdrop-filter 0.4s,border-color 0.4s;
  border-bottom:1px solid transparent;
}
.nav.scrolled{
  background:rgba(245,240,234,0.92);backdrop-filter:blur(20px);
  -webkit-backdrop-filter:blur(20px);border-bottom-color:var(--border);
}
.nav-brand{
  font-family:var(--serif);font-size:1.4rem;font-weight:400;
  letter-spacing:0.04em;color:var(--white);
  transition:color 0.4s;
}
.nav.scrolled .nav-brand{color:var(--text);}
.nav-links{display:flex;gap:clamp(1rem,3vw,2.5rem);align-items:center;}
.nav-link{
  font-size:0.78rem;font-weight:400;letter-spacing:0.06em;
  text-transform:uppercase;color:rgba(255,255,255,0.7);
  transition:color 0.3s;position:relative;
}
.nav-link::after{
  content:'';position:absolute;bottom:-4px;left:0;right:0;height:1px;
  background:currentColor;transform:scaleX(0);transition:transform 0.3s var(--ease);
  transform-origin:right;
}
.nav-link:hover::after{transform:scaleX(1);transform-origin:left;}
.nav.scrolled .nav-link{color:var(--text-light);}
.nav-link:hover{color:var(--white);}
.nav.scrolled .nav-link:hover{color:var(--text);}
.nav-menu-btn{
  display:none;width:24px;height:18px;position:relative;
  flex-direction:column;justify-content:space-between;
}
.nav-menu-btn span{
  display:block;height:1.5px;background:var(--white);
  transition:all 0.3s var(--ease);
}
.nav.scrolled .nav-menu-btn span{background:var(--text);}

/* Mobile nav */
@media(max-width:768px){
  .nav-links{
    position:fixed;inset:0;background:var(--bg-dark);
    flex-direction:column;justify-content:center;align-items:center;gap:2rem;
    opacity:0;visibility:hidden;transition:all 0.5s var(--ease);
  }
  .nav-links.open{opacity:1;visibility:visible;}
  .nav-links .nav-link{color:rgba(255,255,255,0.7);font-size:1rem;letter-spacing:0.1em;}
  .nav-links .nav-link:hover{color:var(--white);}
  .nav-menu-btn{display:flex;}
}

/* ============================================================
   HERO
   ============================================================ */
.hero{
  position:relative;height:100vh;min-height:600px;
  display:flex;align-items:center;justify-content:center;
  overflow:hidden;background:var(--bg-dark);
}
.hero-bg{
  position:absolute;inset:-20px;
  background:url('https://images.unsplash.com/photo-1462275646964-a0e3c11f18a6?w=1920&q=80&auto=format&fit=crop') center/cover no-repeat;
  animation:kenBurns 25s ease-in-out infinite alternate;
  will-change:transform;
}
@keyframes kenBurns{
  0%{transform:scale(1.05) translate(0,0);}
  100%{transform:scale(1.15) translate(-1%,-1%);}
}
.hero-overlay{
  position:absolute;inset:0;
  background:linear-gradient(180deg,rgba(26,24,21,0.35) 0%,rgba(26,24,21,0.55) 60%,rgba(26,24,21,0.75) 100%);
}
.hero-content{
  position:relative;z-index:2;text-align:center;
  padding:0 2rem;max-width:900px;
}
.hero-eyebrow{
  font-family:var(--sans);font-size:0.72rem;font-weight:400;
  letter-spacing:0.25em;text-transform:uppercase;
  color:rgba(255,255,255,0.6);margin-bottom:2rem;
  display:flex;align-items:center;justify-content:center;gap:12px;
}
.hero-eyebrow::before,.hero-eyebrow::after{
  content:'';width:40px;height:1px;background:rgba(255,255,255,0.3);
}
.hero h1{
  font-family:var(--serif);font-weight:300;
  font-size:clamp(3.5rem,10vw,8rem);line-height:0.9;
  letter-spacing:-0.02em;color:var(--white);margin-bottom:0.5em;
}
.hero h1 .accent{
  display:block;font-style:italic;font-weight:300;
  color:var(--gold);
}
.hero-sub{
  font-family:var(--serif);font-style:italic;font-weight:300;
  font-size:clamp(1rem,2vw,1.3rem);
  color:rgba(255,255,255,0.7);max-width:480px;margin:0 auto 3rem;
  line-height:1.5;
}
.hero-cta{
  display:inline-flex;align-items:center;gap:10px;
  padding:16px 36px;border:1px solid rgba(255,255,255,0.3);
  border-radius:0;color:var(--white);
  font-size:0.78rem;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;
  transition:all 0.4s var(--ease);
  background:transparent;
}
.hero-cta:hover{background:var(--white);color:var(--bg-dark);border-color:var(--white);}
.hero-cta svg{width:14px;height:14px;transition:transform 0.3s;}
.hero-cta:hover svg{transform:translateX(4px);}
.hero-scroll{
  position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);z-index:2;
  display:flex;flex-direction:column;align-items:center;gap:8px;
}
.hero-scroll span{
  font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;
  color:rgba(255,255,255,0.4);
}
.hero-scroll-line{
  width:1px;height:40px;background:rgba(255,255,255,0.2);
  position:relative;overflow:hidden;
}
.hero-scroll-line::after{
  content:'';position:absolute;top:-100%;left:0;width:100%;height:100%;
  background:rgba(255,255,255,0.8);animation:scrollLine 2s ease-in-out infinite;
}
@keyframes scrollLine{0%{top:-100%;}100%{top:100%;}}

/* Floating petals */
.petals{position:absolute;inset:0;z-index:1;pointer-events:none;overflow:hidden;}
.petal{
  position:absolute;width:12px;height:12px;
  background:rgba(255,220,220,0.25);border-radius:50% 0 50% 50%;
  animation:petalFall linear infinite;
  will-change:transform;
}
@keyframes petalFall{
  0%{transform:translateY(-10vh) rotate(0deg) translateX(0);opacity:0;}
  10%{opacity:1;}
  90%{opacity:1;}
  100%{transform:translateY(110vh) rotate(720deg) translateX(80px);opacity:0;}
}

/* ============================================================
   MARQUEE
   ============================================================ */
.marquee{
  padding:20px 0;border-top:1px solid var(--border);
  border-bottom:1px solid var(--border);overflow:hidden;
  background:var(--bg);
}
.marquee-track{display:flex;width:max-content;animation:marquee 60s linear infinite;}
.marquee-track:hover{animation-play-state:paused;}
.marquee-item{
  font-family:var(--serif);font-size:1.1rem;font-weight:300;
  color:var(--text-light);white-space:nowrap;padding:0 2rem;
  display:flex;align-items:center;gap:2rem;
}
.marquee-dot{width:4px;height:4px;border-radius:50%;background:var(--gold);flex-shrink:0;}
@keyframes marquee{from{transform:translateX(0);}to{transform:translateX(-50%);}}

/* ============================================================
   SECTION COMMONS
   ============================================================ */
.section{max-width:1400px;margin:0 auto;padding:clamp(80px,12vw,160px) clamp(1.5rem,4vw,3rem);}
.section-eyebrow{
  font-family:var(--sans);font-size:0.68rem;font-weight:500;
  letter-spacing:0.2em;text-transform:uppercase;color:var(--sage);
  margin-bottom:1.5rem;
}
.section-title{
  font-family:var(--serif);font-weight:300;
  font-size:clamp(2.2rem,5vw,4rem);line-height:1.05;
  letter-spacing:-0.02em;margin-bottom:0.4em;
}
.section-title em{font-style:italic;color:var(--accent);}
.section-desc{
  font-family:var(--serif);font-style:italic;font-weight:300;
  color:var(--text-light);font-size:clamp(1rem,1.5vw,1.15rem);
  margin-bottom:4rem;max-width:540px;line-height:1.6;
}

/* ============================================================
   INTRO / ABOUT
   ============================================================ */
.intro{
  display:grid;grid-template-columns:1fr 1fr;gap:clamp(2rem,6vw,6rem);
  align-items:center;
}
.intro-text .section-eyebrow{margin-bottom:1rem;}
.intro-text h2{
  font-family:var(--serif);font-weight:300;
  font-size:clamp(2rem,4vw,3.2rem);line-height:1.1;
  letter-spacing:-0.02em;margin-bottom:1.5rem;
}
.intro-text h2 em{font-style:italic;color:var(--accent);}
.intro-text p{
  font-size:0.95rem;color:var(--text-light);line-height:1.8;
  margin-bottom:1.25rem;
}
.intro-text .stat-row{
  display:flex;gap:3rem;margin-top:2.5rem;padding-top:2rem;
  border-top:1px solid var(--border);
}
.stat{text-align:left;}
.stat-num{
  font-family:var(--serif);font-size:2.5rem;font-weight:300;
  color:var(--sage);line-height:1;margin-bottom:0.25rem;
}
.stat-label{font-size:0.72rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--text-muted);}
.intro-img{
  position:relative;overflow:hidden;aspect-ratio:3/4;
}
.intro-img img{
  width:100%;height:100%;object-fit:cover;
  transition:transform 8s var(--ease);
}
.intro-img:hover img{transform:scale(1.05);}
.intro-img::after{
  content:'';position:absolute;inset:0;
  border:1px solid rgba(255,255,255,0.1);pointer-events:none;
}
@media(max-width:768px){
  .intro{grid-template-columns:1fr;gap:3rem;}
  .intro-img{max-height:50vh;}
}

/* ============================================================
   IN SEASON — HORIZONTAL SCROLL GALLERY
   ============================================================ */
.gallery-section{
  padding:clamp(80px,12vw,160px) 0;overflow:hidden;
}
.gallery-header{
  max-width:1400px;margin:0 auto;
  padding:0 clamp(1.5rem,4vw,3rem) 4rem;
}
.gallery{overflow:visible;position:relative;}
.gallery-track{
  display:flex;gap:1.5rem;
  padding:0 clamp(1.5rem,4vw,3rem);
  will-change:transform;
}
.gallery-card{
  flex:0 0 auto;width:clamp(300px,30vw,420px);
  position:relative;overflow:hidden;cursor:pointer;
  background:var(--bg-dark);
}
.gallery-card-img{
  width:100%;aspect-ratio:3/4;object-fit:cover;
  transition:transform 0.8s var(--ease),opacity 0.5s;
  opacity:0.85;
}
.gallery-card:hover .gallery-card-img{transform:scale(1.08);opacity:1;}
.gallery-card-info{
  position:absolute;bottom:0;left:0;right:0;
  padding:3rem 1.75rem 1.75rem;
  background:linear-gradient(transparent,rgba(26,24,21,0.85));
}
.gallery-card-name{
  font-family:var(--serif);font-size:1.6rem;font-weight:400;
  color:var(--white);margin-bottom:0.3em;
}
.gallery-card-when{
  font-size:0.75rem;letter-spacing:0.08em;text-transform:uppercase;
  color:rgba(255,255,255,0.6);
}
.gallery-card-status{
  position:absolute;top:1.25rem;right:1.25rem;
  padding:6px 14px;font-size:0.65rem;font-weight:500;
  letter-spacing:0.08em;text-transform:uppercase;
  backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);
  border:1px solid rgba(255,255,255,0.15);color:var(--white);
}
.gallery-card-status.st-peak{background:rgba(94,107,82,0.8);}
.gallery-card-status.st-blooming{background:rgba(184,149,106,0.7);}
.gallery-card-status.st-ending{background:rgba(176,136,136,0.7);}
.gallery-card-status.st-upcoming{background:rgba(26,24,21,0.5);}
.gallery-card-status.st-waiting{background:rgba(26,24,21,0.4);}

/* ============================================================
   PARALLAX DIVIDER
   ============================================================ */
.parallax-divider{
  position:relative;height:70vh;min-height:400px;
  overflow:hidden;display:flex;align-items:center;justify-content:center;
}
.parallax-bg{
  position:absolute;inset:-80px;
  background-size:cover;background-position:center;
  background-attachment:fixed;
  will-change:transform;
}
@media(max-width:768px){.parallax-bg{background-attachment:scroll;}}
.parallax-overlay{
  position:absolute;inset:0;
  background:rgba(26,24,21,0.5);
}
.parallax-content{
  position:relative;z-index:2;text-align:center;
  max-width:700px;padding:0 2rem;
}
.parallax-content h2{
  font-family:var(--serif);font-weight:300;font-style:italic;
  font-size:clamp(2rem,4.5vw,3.5rem);color:var(--white);
  line-height:1.2;margin-bottom:0.75em;
}
.parallax-content p{
  font-family:var(--serif);font-weight:300;
  color:rgba(255,255,255,0.7);font-size:1.05rem;
}

/* ============================================================
   WEEKEND EDIT
   ============================================================ */
.weekend-grid{
  display:grid;grid-template-columns:1.2fr 1fr;gap:1.5rem;
}
.weekend-card{
  position:relative;overflow:hidden;background:var(--bg-dark);
  cursor:pointer;
}
.weekend-card-img{
  width:100%;height:100%;min-height:400px;object-fit:cover;
  transition:transform 0.8s var(--ease),opacity 0.5s;opacity:0.8;
}
.weekend-card:hover .weekend-card-img{transform:scale(1.05);opacity:1;}
.weekend-card-overlay{
  position:absolute;inset:0;
  background:linear-gradient(transparent 30%,rgba(26,24,21,0.8));
}
.weekend-card-content{
  position:absolute;bottom:0;left:0;right:0;
  padding:2rem;
}
.weekend-card-tag{
  display:inline-block;padding:5px 14px;
  font-size:0.65rem;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;
  color:var(--white);margin-bottom:1rem;
  border:1px solid rgba(255,255,255,0.2);
  backdrop-filter:blur(8px);
}
.weekend-card-tag.pk{background:rgba(94,107,82,0.7);}
.weekend-card-tag.bl{background:rgba(184,149,106,0.6);}
.weekend-card-tag.en{background:rgba(176,136,136,0.6);}
.weekend-card-title{
  font-family:var(--serif);font-weight:400;
  font-size:clamp(1.4rem,2.5vw,2rem);color:var(--white);
  margin-bottom:0.3em;
}
.weekend-card-loc{
  font-size:0.82rem;color:rgba(255,255,255,0.65);
  display:flex;align-items:center;gap:6px;
}
.weekend-card-loc svg{width:14px;height:14px;opacity:0.6;}
.weekend-card-desc{
  font-size:0.85rem;color:rgba(255,255,255,0.55);margin-top:0.5rem;
  line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;
}
.weekend-side{display:flex;flex-direction:column;gap:1.5rem;}
@media(max-width:900px){
  .weekend-grid{grid-template-columns:1fr;}
  .weekend-card-img{min-height:300px;}
}

/* ============================================================
   BLOOM GUIDE — EDITORIAL BLOCKS
   ============================================================ */
.guide-block{
  display:grid;grid-template-columns:1fr 1fr;gap:clamp(2rem,5vw,5rem);
  align-items:center;padding:clamp(40px,8vw,100px) 0;
  border-bottom:1px solid var(--border);
}
.guide-block:last-child{border-bottom:none;}
.guide-block:nth-child(even) .guide-img{order:-1;}
.guide-img{
  position:relative;overflow:hidden;aspect-ratio:4/5;
  clip-path:inset(0 0 0 0);
}
.guide-img img{
  width:100%;height:100%;object-fit:cover;
  transition:transform 1.2s var(--ease);
}
.guide-block:hover .guide-img img{transform:scale(1.04);}
.guide-text{padding:clamp(0,2vw,2rem) 0;}
.guide-flower-name{
  font-family:var(--serif);font-weight:300;
  font-size:clamp(2rem,4vw,3rem);line-height:1.1;
  letter-spacing:-0.02em;margin-bottom:0.3em;
}
.guide-flower-when{
  font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;
  color:var(--gold);margin-bottom:1.5rem;
}
.guide-flower-desc{
  font-family:var(--serif);font-size:1.1rem;font-weight:300;
  color:var(--text-light);line-height:1.7;margin-bottom:2rem;
}
.guide-locations{
  display:flex;flex-wrap:wrap;gap:8px;margin-bottom:1.5rem;
}
.loc-tag{
  padding:6px 16px;font-size:0.75rem;font-weight:400;
  border:1px solid var(--border);color:var(--text-light);
  transition:all 0.3s var(--ease);position:relative;
  cursor:pointer;letter-spacing:0.02em;
}
.loc-tag:hover{border-color:var(--sage);color:var(--sage);background:var(--sage-light);}
.guide-share{
  display:inline-flex;align-items:center;gap:8px;
  font-size:0.75rem;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;
  color:var(--text-muted);transition:color 0.3s;
  padding-top:1.5rem;border-top:1px solid var(--border);
}
.guide-share:hover{color:var(--sage);}
.guide-share svg{width:14px;height:14px;}
@media(max-width:768px){
  .guide-block{grid-template-columns:1fr;gap:2rem;}
  .guide-block:nth-child(even) .guide-img{order:0;}
  .guide-img{max-height:50vh;}
}

/* ============================================================
   MAP PREVIEW TOOLTIP (for location hover)
   ============================================================ */
.map-tooltip{
  position:fixed;z-index:10000;pointer-events:none;
  width:280px;height:200px;
  box-shadow:var(--shadow-lg);border:1px solid var(--border);
  overflow:hidden;opacity:0;
  transition:opacity 0.3s var(--ease);
  background:var(--white);
}
.map-tooltip.visible{opacity:1;}
.map-tooltip .leaflet-container{width:100%;height:160px;}
.map-tooltip-info{
  padding:8px 12px;background:var(--white);
  font-size:0.72rem;color:var(--text-light);
  border-top:1px solid var(--border);
}
.map-tooltip-name{font-weight:500;color:var(--text);}

/* ============================================================
   DESTINATIONS
   ============================================================ */
.dest-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(340px,1fr));
  gap:1.25rem;
}
.dest-card{
  position:relative;overflow:hidden;background:var(--bg-dark);
  aspect-ratio:4/3;cursor:pointer;
}
.dest-card-img{
  width:100%;height:100%;object-fit:cover;
  transition:transform 0.8s var(--ease),opacity 0.5s;opacity:0.75;
}
.dest-card:hover .dest-card-img{transform:scale(1.06);opacity:1;}
.dest-card-overlay{
  position:absolute;inset:0;
  background:linear-gradient(transparent 40%,rgba(26,24,21,0.85));
}
.dest-card-content{
  position:absolute;bottom:0;left:0;right:0;padding:1.5rem;
}
.dest-card-name{
  font-family:var(--serif);font-size:1.25rem;font-weight:400;
  color:var(--white);margin-bottom:0.2em;
}
.dest-card-flowers{
  font-size:0.75rem;color:rgba(255,255,255,0.6);
}
.dest-card-region{
  position:absolute;top:1rem;left:1rem;
  padding:4px 12px;font-size:0.62rem;font-weight:500;
  letter-spacing:0.08em;text-transform:uppercase;
  color:var(--white);background:rgba(26,24,21,0.5);
  backdrop-filter:blur(8px);
}
@media(max-width:600px){
  .dest-grid{grid-template-columns:1fr;}
}

/* ============================================================
   CALENDAR
   ============================================================ */
.cal-wrap{
  background:var(--white);border:1px solid var(--border);
  padding:2.5rem;overflow-x:auto;
}
.cal-table{width:100%;min-width:800px;border-collapse:collapse;}
.cal-table th{
  font-family:var(--sans);font-size:0.65rem;font-weight:500;
  letter-spacing:0.1em;text-transform:uppercase;color:var(--text-muted);
  padding:10px 4px;text-align:center;border-bottom:1px solid var(--border);
}
.cal-table th.current{color:var(--sage);border-bottom-color:var(--sage);}
.cal-table td{padding:6px 3px;text-align:center;vertical-align:middle;}
.cal-table td:first-child{
  font-family:var(--serif);font-weight:400;font-size:0.9rem;
  text-align:left;padding-left:4px;white-space:nowrap;min-width:140px;
  color:var(--text);
}
.bar{
  height:24px;display:flex;align-items:center;justify-content:center;
  font-size:0.62rem;transition:transform 0.2s;cursor:default;
}
.bar:hover{transform:scaleY(1.3);}
.bar.peak{background:var(--sage);color:var(--white);font-weight:500;}
.bar.bloom{background:var(--sage-light);color:var(--sage);font-weight:500;}
.cal-legend{
  display:flex;gap:2rem;margin-top:1.5rem;
}
.cal-legend-item{
  display:flex;align-items:center;gap:8px;
  font-size:0.75rem;color:var(--text-light);
}
.cal-legend-swatch{width:24px;height:10px;}

/* ============================================================
   MAP SECTION
   ============================================================ */
.map-section-wrap{
  background:var(--white);border:1px solid var(--border);
  overflow:hidden;
}
.map-filters{
  padding:1rem 1.5rem;display:flex;gap:8px;flex-wrap:wrap;
  border-bottom:1px solid var(--border);
}
.map-filter{
  padding:6px 16px;font-size:0.75rem;font-weight:400;
  letter-spacing:0.02em;border:1px solid var(--border);
  color:var(--text-light);transition:all 0.3s;background:transparent;
}
.map-filter:hover{border-color:var(--sage);color:var(--sage);}
.map-filter.active{background:var(--bg-dark);color:var(--bg);border-color:var(--bg-dark);}
#leaflet-map{height:560px;width:100%;}

/* Leaflet custom */
.leaflet-popup-content-wrapper{
  border-radius:0!important;
  box-shadow:var(--shadow-lg)!important;
  font-family:var(--sans)!important;padding:0!important;
  border:1px solid var(--border)!important;
}
.leaflet-popup-content{margin:0!important;min-width:250px;}
.leaflet-popup-tip{box-shadow:none!important;}
.map-popup{padding:0;}
.map-popup-img{width:100%;height:140px;object-fit:cover;}
.map-popup-body{padding:1.25rem;}
.map-popup-name{
  font-family:var(--serif);font-weight:500;font-size:1.1rem;margin-bottom:0.4em;
}
.map-popup-flowers{font-size:0.78rem;color:var(--sage);font-weight:500;margin-bottom:0.5em;}
.map-popup-desc{font-size:0.82rem;color:var(--text-light);line-height:1.5;margin-bottom:0.75em;}
.map-popup-status{
  display:inline-block;padding:3px 12px;
  font-size:0.62rem;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;
}
.custom-marker{
  display:flex;align-items:center;justify-content:center;
  width:36px;height:36px;border-radius:50%;
  border:2px solid var(--white);
  box-shadow:0 2px 12px rgba(26,24,21,0.2);
  transition:transform 0.3s var(--ease);
  font-size:0;overflow:hidden;
}
.custom-marker:hover{transform:scale(1.2);}
.custom-marker img{width:100%;height:100%;object-fit:cover;}

/* ============================================================
   FOOTER
   ============================================================ */
footer{
  border-top:1px solid var(--border);
  padding:clamp(60px,8vw,120px) clamp(1.5rem,4vw,3rem) clamp(30px,4vw,60px);
}
.footer-inner{
  max-width:1400px;margin:0 auto;
  display:grid;grid-template-columns:1fr auto;gap:3rem;align-items:end;
}
.footer-brand{
  font-family:var(--serif);font-size:clamp(2rem,4vw,3rem);
  font-weight:300;letter-spacing:-0.02em;margin-bottom:1rem;
}
.footer-brand em{font-style:italic;color:var(--accent);}
.footer-tagline{
  font-family:var(--serif);font-style:italic;font-weight:300;
  color:var(--text-light);font-size:0.95rem;margin-bottom:2rem;
}
.footer-links{display:flex;gap:2rem;flex-wrap:wrap;}
.footer-link{
  font-size:0.75rem;letter-spacing:0.06em;text-transform:uppercase;
  color:var(--text-muted);transition:color 0.3s;
}
.footer-link:hover{color:var(--text);}
.footer-right{text-align:right;}
.footer-copy{font-size:0.75rem;color:var(--text-muted);margin-bottom:0.5rem;}
.footer-note{font-size:0.7rem;color:var(--text-muted);max-width:300px;line-height:1.5;margin-left:auto;}
.footer-gh{color:var(--sage);text-decoration:underline;text-underline-offset:2px;}
@media(max-width:768px){
  .footer-inner{grid-template-columns:1fr;gap:2rem;}
  .footer-right{text-align:left;}
  .footer-note{margin-left:0;}
}

/* ============================================================
   SHARE TOAST
   ============================================================ */
.share-toast{
  position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(80px);
  background:var(--bg-dark);color:var(--bg);
  padding:14px 28px;font-size:0.82rem;font-weight:500;
  letter-spacing:0.04em;box-shadow:var(--shadow-lg);
  z-index:9000;transition:transform 0.5s var(--ease-out),opacity 0.5s;
  opacity:0;pointer-events:none;
}
.share-toast.show{transform:translateX(-50%) translateY(0);opacity:1;}

/* ============================================================
   REVEAL ANIMATIONS (base states)
   ============================================================ */
.reveal{opacity:0;transform:translateY(40px);transition:opacity 0.8s var(--ease),transform 0.8s var(--ease);}
.reveal.visible{opacity:1;transform:none;}
.reveal-img{clip-path:inset(100% 0 0 0);transition:clip-path 1s var(--ease);}
.reveal-img.visible{clip-path:inset(0 0 0 0);}
.reveal-slide-left{opacity:0;transform:translateX(-60px);transition:opacity 0.8s var(--ease),transform 0.8s var(--ease);}
.reveal-slide-left.visible{opacity:1;transform:none;}
.reveal-slide-right{opacity:0;transform:translateX(60px);transition:opacity 0.8s var(--ease),transform 0.8s var(--ease);}
.reveal-slide-right.visible{opacity:1;transform:none;}

/* ============================================================
   UTILITY
   ============================================================ */
.full-bleed{max-width:none;padding-left:0;padding-right:0;}
.visually-hidden{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);}
</style>
</head>
<body>

<!-- PRELOADER -->
<div class="preloader" id="preloader">
  <div class="preloader-text">DMV Blooms</div>
</div>

<!-- CUSTOM CURSOR -->
<div class="cursor" id="cursor"></div>

<!-- NAVIGATION -->
<nav class="nav" id="nav">
  <a href="#top" class="nav-brand">DMV Blooms</a>
  <div class="nav-links" id="nav-links">
    <a href="#in-season" class="nav-link">In Season</a>
    <a href="#weekend" class="nav-link">This Weekend</a>
    <a href="#guide" class="nav-link">Guide</a>
    <a href="#destinations" class="nav-link">Destinations</a>
    <a href="#calendar" class="nav-link">Calendar</a>
    <a href="#map-section" class="nav-link">Map</a>
  </div>
  <button class="nav-menu-btn" id="nav-toggle" aria-label="Toggle menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- HERO -->
<section class="hero" id="top">
  <div class="hero-bg"></div>
  <div class="hero-overlay"></div>
  <div class="petals" id="petals"></div>
  <div class="hero-content">
    <div class="hero-eyebrow"><span id="hero-count">12 Flowers Tracked</span></div>
    <h1>DMV<span class="accent">Blooms</span></h1>
    <p class="hero-sub">A seasonal field guide to the most beautiful flowers across Washington DC, Maryland & Virginia.</p>
    <a href="#in-season" class="hero-cta">
      Explore what's blooming
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
  <div class="hero-scroll">
    <span>Scroll</span>
    <div class="hero-scroll-line"></div>
  </div>
</section>

<!-- MARQUEE -->
<div class="marquee">
  <div class="marquee-track" id="marquee-track"></div>
</div>

<!-- INTRO -->
<section class="section" id="intro">
  <div class="intro">
    <div class="intro-text">
      <div class="section-eyebrow reveal">About the Guide</div>
      <h2 class="reveal">Where to find the <em>most beautiful</em> blooms in the DMV</h2>
      <p class="reveal">From the iconic cherry blossoms of the Tidal Basin to hidden bluebell forests in Virginia, the DC metropolitan area is home to an extraordinary diversity of seasonal flowers.</p>
      <p class="reveal">This guide tracks what's blooming right now, where to find it, and when to visit — updated for each season so you never miss a peak.</p>
      <div class="stat-row reveal">
        <div class="stat">
          <div class="stat-num" id="stat-flowers">12</div>
          <div class="stat-label">Flower Species</div>
        </div>
        <div class="stat">
          <div class="stat-num" id="stat-locations">20</div>
          <div class="stat-label">Locations</div>
        </div>
        <div class="stat">
          <div class="stat-num" id="stat-active">—</div>
          <div class="stat-label">In Bloom Now</div>
        </div>
      </div>
    </div>
    <div class="intro-img reveal-img">
      <img src="https://images.unsplash.com/photo-1490750967868-88aa4f44baee?w=800&q=80&auto=format&fit=crop" alt="Colorful tulips in bloom" loading="lazy">
    </div>
  </div>
</section>

<!-- IN SEASON — HORIZONTAL GALLERY -->
<section class="gallery-section" id="in-season">
  <div class="gallery-header">
    <div class="section-eyebrow reveal">In Season</div>
    <h2 class="section-title reveal">What's blooming <em>now</em></h2>
    <p class="section-desc reveal" id="gallery-desc"></p>
  </div>
  <div class="gallery" id="gallery">
    <div class="gallery-track" id="gallery-track"></div>
  </div>
</section>

<!-- PARALLAX DIVIDER -->
<div class="parallax-divider">
  <div class="parallax-bg" style="background-image:url('https://images.unsplash.com/photo-1522383225653-ed111181a951?w=1920&q=80&auto=format&fit=crop')"></div>
  <div class="parallax-overlay"></div>
  <div class="parallax-content">
    <h2 class="reveal">"The earth laughs in flowers."</h2>
    <p class="reveal">— Ralph Waldo Emerson</p>
  </div>
</div>

<!-- WEEKEND EDIT -->
<section class="section" id="weekend">
  <div class="section-eyebrow reveal">The Weekend Edit</div>
  <h2 class="section-title reveal" id="weekend-title">Where to go this weekend</h2>
  <p class="section-desc reveal">Our curated picks for the best bloom-chasing this weekend, based on what's peaking right now.</p>
  <div class="weekend-grid" id="weekend-grid"></div>
</section>

<!-- BLOOM GUIDE -->
<section class="section" id="guide">
  <div class="section-eyebrow reveal">The Guide</div>
  <h2 class="section-title reveal">A field guide to <em>every bloom</em></h2>
  <p class="section-desc reveal">Twelve species, from the first magnolias of March to the last sunflowers of September.</p>
  <div id="guide-container"></div>
</section>

<!-- DESTINATIONS -->
<section class="section" id="destinations">
  <div class="section-eyebrow reveal">Destinations</div>
  <h2 class="section-title reveal">Where to <em>go</em></h2>
  <p class="section-desc reveal">Twenty of our favorite bloom spots across DC, Maryland and Virginia. Hover to preview the location.</p>
  <div class="dest-grid" id="dest-grid"></div>
</section>

<!-- CALENDAR -->
<section class="section" id="calendar">
  <div class="section-eyebrow reveal">Seasonality</div>
  <h2 class="section-title reveal">The bloom <em>calendar</em></h2>
  <p class="section-desc reveal">A year of DMV flowers at a glance. Plan ahead — or see what's next.</p>
  <div class="cal-wrap reveal">
    <table class="cal-table" id="cal-table"></table>
    <div class="cal-legend">
      <div class="cal-legend-item"><div class="cal-legend-swatch" style="background:var(--sage)"></div>Peak bloom</div>
      <div class="cal-legend-item"><div class="cal-legend-swatch" style="background:var(--sage-light)"></div>Early / late bloom</div>
    </div>
  </div>
</section>

<!-- MAP -->
<section class="section full-bleed" id="map-section">
  <div style="max-width:1400px;margin:0 auto;padding:0 clamp(1.5rem,4vw,3rem);">
    <div class="section-eyebrow reveal">Explore</div>
    <h2 class="section-title reveal">Find your <em>bloom</em></h2>
    <p class="section-desc reveal">All twenty locations on one map. Tap a pin to see what's there.</p>
  </div>
  <div style="max-width:1400px;margin:0 auto;padding:0 clamp(1.5rem,4vw,3rem);">
    <div class="map-section-wrap reveal">
      <div class="map-filters" id="map-filters"></div>
      <div id="leaflet-map"></div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="footer-inner">
    <div class="footer-left">
      <div class="footer-brand">DMV <em>Blooms</em></div>
      <p class="footer-tagline">Made for the DMV flower-chasing community.</p>
      <div class="footer-links">
        <a href="#in-season" class="footer-link">In Season</a>
        <a href="#guide" class="footer-link">Guide</a>
        <a href="#destinations" class="footer-link">Destinations</a>
        <a href="#calendar" class="footer-link">Calendar</a>
        <a href="#map-section" class="footer-link">Map</a>
      </div>
    </div>
    <div class="footer-right">
      <p class="footer-copy">&copy; <span id="year"></span> Isfar Baset. All rights reserved.</p>
      <p class="footer-note">Bloom times are approximate and vary by weather. <a class="footer-gh" href="https://github.com/isfarbaset/dmv-blooms">Contribute on GitHub.</a></p>
    </div>
  </div>
</footer>

<!-- SHARE TOAST -->
<div class="share-toast" id="share-toast">Link copied to clipboard</div>

<!-- MAP TOOLTIP -->
<div class="map-tooltip" id="map-tooltip">
  <div id="map-tooltip-map" style="width:100%;height:160px;"></div>
  <div class="map-tooltip-info">
    <div class="map-tooltip-name" id="map-tooltip-name"></div>
  </div>
</div>

<script>
/* ============================================================
   DATA
   ============================================================ */
const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const NOW = new Date(), CM = NOW.getMonth(), CD = NOW.getDate();

const BLOOMS = [
  { n:"Cherry Blossoms", img:"https://images.unsplash.com/photo-1522383225653-ed111181a951?w=800&q=80&auto=format&fit=crop", mo:[2,3], pk:[2,3], wk:"Late Mar – Early Apr", d:"DC's signature bloom. Yoshino cherries turn the Tidal Basin into clouds of pale pink. Kwanzan varieties follow two to three weeks later with deeper color.", c:"#e8d5d5", loc:["Tidal Basin","National Arboretum","Kenwood, MD","Hains Point","Congressional Cemetery"] },
  { n:"Magnolias", img:"https://images.unsplash.com/photo-1520412099551-62b6bafeb5bb?w=800&q=80&auto=format&fit=crop", mo:[2,3], pk:[2], wk:"Early – Mid Mar", d:"Saucer magnolias in pink, white and purple appear a few weeks before the cherries. Enormous blooms, surprisingly fragrant.", c:"#e8dce8", loc:["Enid Haupt Garden","Dumbarton Oaks","Rock Creek Park","Hillwood Estate"] },
  { n:"Tulips", img:"https://images.unsplash.com/photo-1524386416438-98b9b2d4b433?w=800&q=80&auto=format&fit=crop", mo:[3,4], pk:[3], wk:"Early – Mid Apr", d:"Every color you can imagine. The Floral Library has 10,000 bulbs in 93 beds. Burnside Farms plants two million across 30 varieties.", c:"#f0ddd5", loc:["Floral Library","Burnside Farms, VA","Netherlands Carillon","U.S. Capitol Grounds"] },
  { n:"Bluebells", img:"https://images.unsplash.com/photo-1588714477688-cf28a50e94f7?w=800&q=80&auto=format&fit=crop", mo:[2,3], pk:[3], wk:"Late Mar – Mid Apr", d:"Virginia bluebells carpet riverside forests in waves of purple-blue. Blink and you'll miss them — the season is short and enchanting.", c:"#d5dce8", loc:["Bull Run Regional Park","Riverbend Park, VA","C&O Canal","Great Falls Park"] },
  { n:"Azaleas", img:"https://images.unsplash.com/photo-1558642452-9d2a7deb7f62?w=800&q=80&auto=format&fit=crop", mo:[3,4], pk:[3,4], wk:"Late Apr – Mid May", d:"Mount Hamilton at the Arboretum becomes a hillside of red, pink, purple and white. Peak happens in stages over several weeks.", c:"#e8d5dd", loc:["National Arboretum","Franciscan Monastery","Brookside Gardens, MD","Dumbarton Oaks"] },
  { n:"Wisteria", img:"https://images.unsplash.com/photo-1399055124039-59e9346a3f9f?w=800&q=80&auto=format&fit=crop", mo:[3,4], pk:[3,4], wk:"Apr – May", d:"Cascading purple racemes dripping from pergolas and stone walls. Dumbarton Oaks and Georgetown's R Street are the spots.", c:"#ddd5e8", loc:["Dumbarton Oaks","Georgetown streets","Tudor Place","National Cathedral"] },
  { n:"Lilacs", img:"https://images.unsplash.com/photo-1595231776515-ddffb1f4eb73?w=800&q=80&auto=format&fit=crop", mo:[3], pk:[3], wk:"April", d:"Fragrant purple and white clusters. Georgetown's lilac-covered walls are a spring tradition worth seeking out.", c:"#ddd5e5", loc:["Georgetown","Dumbarton Oaks","National Arboretum"] },
  { n:"Roses", img:"https://images.unsplash.com/photo-1455659817273-f96807779a8a?w=800&q=80&auto=format&fit=crop", mo:[5,6,7], pk:[5,6], wk:"Jun – Aug", d:"Summer heat brings out the roses. The Botanic Garden's collection and the Bon Air Rose Garden in Arlington are standouts.", c:"#e8d5d5", loc:["U.S. Botanic Garden","Franciscan Monastery","Bon Air Rose Garden, VA","Brookside Gardens, MD"] },
  { n:"Hydrangeas", img:"https://images.unsplash.com/photo-1527325678964-54b9f5e8b5a8?w=800&q=80&auto=format&fit=crop", mo:[5,6,7], pk:[5,6], wk:"Jun – Jul", d:"Big clusters of blue, pink and white that love the DMV's humidity. Yards Park has a surprisingly good showing.", c:"#d5dce5", loc:["Yards Park","Georgetown","Franciscan Monastery","Tudor Place"] },
  { n:"Lavender", img:"https://images.unsplash.com/photo-1499002238440-d264edd596ec?w=800&q=80&auto=format&fit=crop", mo:[5,6], pk:[5,6], wk:"Jun – Jul", d:"Rolling fields of fragrant purple at farms across Maryland and Virginia. Many open for pick-your-own season.", c:"#ddd5e8", loc:["Seven Oaks Lavender Farm, VA","Soleado Lavender Farm, MD","Springfield Manor, MD"] },
  { n:"Lotus & Water Lilies", img:"https://images.unsplash.com/photo-1524055988636-436cfa46e59e?w=800&q=80&auto=format&fit=crop", mo:[6,7], pk:[6,7], wk:"Jul – Aug", d:"Kenilworth Aquatic Gardens is the only national park dedicated to water flowers. Go early morning for the best blooms.", c:"#d5e5dc", loc:["Kenilworth Aquatic Gardens"] },
  { n:"Sunflowers", img:"https://images.unsplash.com/photo-1551945326-df678ef46d73?w=800&q=80&auto=format&fit=crop", mo:[6,7,8], pk:[6,7], wk:"Mid Jul – Sep", d:"Thirty-plus acres of towering gold at McKee-Beshers. Bring bug spray and a camera. The fields are free to wander.", c:"#e8e5d5", loc:["McKee-Beshers WMA, MD","Burnside Farms, VA"] },
];

const LOCS = [
  {n:"Tidal Basin",la:38.8822,ln:-77.0365,fl:["Cherry Blossoms","Tulips"],d:"3,000+ cherry trees along the water. Sunrise visits are magical and crowd-free.",r:"DC",c:"#e8d5d5",img:"https://images.unsplash.com/photo-1522383225653-ed111181a951?w=640&q=80&auto=format&fit=crop"},
